<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Style TargetType="Window">
    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
    <Setter Property="FontFamily" Value="Segoe UI" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style TargetType="Button">
    <Setter Property="Margin" Value="0,0,10,0" />
    <Setter Property="Padding" Value="14,8" />
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource PrimaryButtonForegroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="8">
            <ContentPresenter HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Margin="{TemplateBinding Padding}" />
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Background" Value="{DynamicResource AccentDarkBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentDarkBrush}" />
      </Trigger>
      <Trigger Property="IsEnabled" Value="False">
        <Setter Property="Opacity" Value="0.55" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
    <Setter Property="Background" Value="{DynamicResource SecondaryButtonBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource SecondaryButtonForegroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SecondaryButtonBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Background" Value="{DynamicResource GhostHoverBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource GhostHoverBorderBrush}" />
      </Trigger>
      <Trigger Property="IsEnabled" Value="False">
        <Setter Property="Opacity" Value="0.55" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="FlatIconButtonStyle" TargetType="Button">
    <Setter Property="Margin" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Opacity" Value="0.9" />
      </Trigger>
      <Trigger Property="IsPressed" Value="True">
        <Setter Property="Opacity" Value="0.8" />
      </Trigger>
      <Trigger Property="IsEnabled" Value="False">
        <Setter Property="Opacity" Value="0.45" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style TargetType="TextBox">
    <Setter Property="Margin" Value="0,0,0,10" />
    <Setter Property="Padding" Value="10,8" />
    <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource ControlForegroundBrush}" />
    <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style TargetType="PasswordBox">
    <Setter Property="Margin" Value="0,0,0,10" />
    <Setter Property="Padding" Value="10,8" />
    <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource ControlForegroundBrush}" />
  </Style>

  <Style TargetType="ComboBox">
    <Setter Property="Margin" Value="0,0,0,10" />
    <Setter Property="Padding" Value="8,6" />
    <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource ControlForegroundBrush}" />
  </Style>

  <Style TargetType="ListBox">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="Background" Value="{DynamicResource CardBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
  </Style>

  <Style TargetType="ComboBoxItem">
    <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource ControlForegroundBrush}" />
    <Style.Triggers>
      <Trigger Property="IsHighlighted" Value="True">
        <Setter Property="Background" Value="{DynamicResource GhostHoverBrush}" />
      </Trigger>
      <Trigger Property="IsSelected" Value="True">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryButtonForegroundBrush}" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style TargetType="DatePicker">
    <Setter Property="Margin" Value="0,0,0,10" />
    <Setter Property="Padding" Value="4" />
    <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource ControlForegroundBrush}" />
  </Style>

  <Style TargetType="DatePickerTextBox">
    <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource ControlForegroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
    <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style TargetType="Calendar">
    <Setter Property="Background" Value="{DynamicResource CardBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
  </Style>

  <Style TargetType="CalendarDayButton">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="Background" Value="{DynamicResource CardBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
  </Style>

  <Style TargetType="CalendarButton">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="Background" Value="{DynamicResource CardBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
  </Style>

  <Style TargetType="ScrollBar">
    <Setter Property="Background" Value="{DynamicResource CardBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource ControlForegroundBrush}" />
  </Style>

  <Style TargetType="CheckBox">
    <Setter Property="Margin" Value="0,4,0,12" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style TargetType="ProgressBar">
    <Setter Property="Foreground" Value="{DynamicResource ProgressBarIndicatorBrush}" />
    <Setter Property="Background" Value="{DynamicResource ProgressBarTrackBrush}" />
  </Style>

  <Style TargetType="DataGrid">
    <Setter Property="GridLinesVisibility" Value="Horizontal" />
    <Setter Property="HeadersVisibility" Value="Column" />
    <Setter Property="CanUserAddRows" Value="False" />
    <Setter Property="CanUserDeleteRows" Value="False" />
    <Setter Property="CanUserResizeRows" Value="False" />
    <Setter Property="SelectionMode" Value="Single" />
    <Setter Property="SelectionUnit" Value="FullRow" />
    <Setter Property="AutoGenerateColumns" Value="True" />
    <Setter Property="RowBackground" Value="{DynamicResource GridRowBackgroundBrush}" />
    <Setter Property="AlternatingRowBackground" Value="{DynamicResource GridRowAlternateBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource GridHeaderBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Background" Value="{DynamicResource CardBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="FontSize" Value="15" />
    <Setter Property="RowHeight" Value="40" />
    <Setter Property="ColumnHeaderHeight" Value="42" />
  </Style>

  <Style TargetType="DataGridColumnHeader">
    <Setter Property="FontSize" Value="15" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Padding" Value="12,6" />
    <Setter Property="Background" Value="{DynamicResource GridHeaderBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource GridHeaderForegroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource GridHeaderBorderBrush}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
  </Style>

  <Style TargetType="DataGridCell">
    <Setter Property="Padding" Value="10,6" />
    <Setter Property="BorderBrush" Value="{DynamicResource GridCellBorderBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style TargetType="DataGridRow">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Style.Triggers>
      <Trigger Property="IsSelected" Value="True">
        <Setter Property="Background" Value="{DynamicResource GridSelectionBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource GridSelectionForegroundBrush}" />
      </Trigger>
    </Style.Triggers>
  </Style>
</ResourceDictionary>
