<Application x:Class="Tournaments.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/LoginWindow.xaml">
  <Application.Resources>
    <Color x:Key="AccentColor">#FF166088</Color>
    <Color x:Key="AccentDarkColor">#FF0E3A52</Color>
    <Color x:Key="SurfaceColor">#FFF7FAFC</Color>
    <Color x:Key="PanelColor">#FF102A43</Color>
    <Color x:Key="GhostHoverColor">#FFF2F8FC</Color>
    <Color x:Key="GhostHoverBorderColor">#FFD4E3EF</Color>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource AccentDarkColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}" />
    <SolidColorBrush x:Key="GhostHoverBrush" Color="{StaticResource GhostHoverColor}" />
    <SolidColorBrush x:Key="GhostHoverBorderBrush" Color="{StaticResource GhostHoverBorderColor}" />

    <Style TargetType="Window">
      <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
      <Setter Property="FontFamily" Value="Segoe UI" />
      <Setter Property="Foreground" Value="#FF1F2933" />
    </Style>

    <Style TargetType="Button">
      <Setter Property="Margin" Value="0,0,10,0" />
      <Setter Property="Padding" Value="14,8" />
      <Setter Property="Background" Value="{StaticResource AccentBrush}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="{TemplateBinding Padding}" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="{StaticResource AccentDarkBrush}" />
          <Setter Property="BorderBrush" Value="{StaticResource AccentDarkBrush}" />
        </Trigger>
        <Trigger Property="IsEnabled" Value="False">
          <Setter Property="Opacity" Value="0.55" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Background" Value="White" />
      <Setter Property="Foreground" Value="{StaticResource AccentDarkBrush}" />
      <Setter Property="BorderBrush" Value="#FFD9E2EC" />
      <Setter Property="BorderThickness" Value="1" />
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="{StaticResource GhostHoverBrush}" />
          <Setter Property="BorderBrush" Value="{StaticResource GhostHoverBorderBrush}" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style TargetType="TextBox">
      <Setter Property="Margin" Value="0,0,0,10" />
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="BorderBrush" Value="#FFBCCCDC" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="White" />
    </Style>

    <Style TargetType="PasswordBox">
      <Setter Property="Margin" Value="0,0,0,10" />
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="BorderBrush" Value="#FFBCCCDC" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="White" />
    </Style>

    <Style TargetType="ComboBox">
      <Setter Property="Margin" Value="0,0,0,10" />
      <Setter Property="Padding" Value="8,6" />
      <Setter Property="BorderBrush" Value="#FFBCCCDC" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="White" />
    </Style>

    <Style TargetType="DatePicker">
      <Setter Property="Margin" Value="0,0,0,10" />
      <Setter Property="Padding" Value="4" />
      <Setter Property="BorderBrush" Value="#FFBCCCDC" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="White" />
    </Style>

    <Style TargetType="CheckBox">
      <Setter Property="Margin" Value="0,4,0,12" />
    </Style>

    <Style TargetType="DataGrid">
      <Setter Property="GridLinesVisibility" Value="Horizontal" />
      <Setter Property="HeadersVisibility" Value="Column" />
      <Setter Property="CanUserAddRows" Value="False" />
      <Setter Property="CanUserDeleteRows" Value="False" />
      <Setter Property="CanUserResizeRows" Value="False" />
      <Setter Property="SelectionMode" Value="Single" />
      <Setter Property="SelectionUnit" Value="FullRow" />
      <Setter Property="AutoGenerateColumns" Value="True" />
      <Setter Property="RowBackground" Value="White" />
      <Setter Property="AlternatingRowBackground" Value="#FFF0F4F8" />
      <Setter Property="BorderBrush" Value="#FFD9E2EC" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontSize" Value="15" />
      <Setter Property="RowHeight" Value="40" />
      <Setter Property="ColumnHeaderHeight" Value="42" />
    </Style>

    <Style TargetType="DataGridColumnHeader">
      <Setter Property="FontSize" Value="15" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Padding" Value="12,6" />
    </Style>

    <Style TargetType="DataGridCell">
      <Setter Property="Padding" Value="10,6" />
    </Style>
  </Application.Resources>
</Application>
