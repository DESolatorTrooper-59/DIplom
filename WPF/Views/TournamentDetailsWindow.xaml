<Window x:Class="Tournaments.WPF.Views.TournamentDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Турнир"
        Width="860"
        Height="620"
        MinWidth="760"
        MinHeight="540"
        Background="{DynamicResource SurfaceBrush}"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="20" Background="{DynamicResource SurfaceBrush}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel>
      <TextBlock Text="{Binding TournamentName}"
                 FontSize="30"
                 FontWeight="Bold"
                 Foreground="{DynamicResource TextPrimaryBrush}" />
      <TextBlock Margin="0,8,0,0"
                 Text="{Binding GameName}"
                 FontSize="16"
                 Foreground="{DynamicResource TextSecondaryBrush}" />
    </StackPanel>

    <Grid Grid.Row="1" Margin="0,18,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="320" />
        <ColumnDefinition Width="24" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0"
              Background="{DynamicResource CardBrush}"
              BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="1"
              CornerRadius="18"
              ClipToBounds="True">
        <Grid>
          <Image Source="{Binding PreviewImage}"
                 Stretch="UniformToFill"
                 Visibility="{Binding PreviewImageVisibility}" />

          <Border Background="{DynamicResource SubtleCardBrush}"
                  Visibility="{Binding PreviewPlaceholderVisibility}">
            <Grid Margin="20">
              <Border Width="92"
                      Height="92"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top"
                      Background="{DynamicResource ThemeToggleActiveBackgroundBrush}"
                      BorderBrush="{DynamicResource ThemeToggleActiveBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="26" />
              <TextBlock Margin="20"
                         VerticalAlignment="Center"
                         FontSize="28"
                         FontWeight="Bold"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         Text="{Binding PreviewPlaceholderText}"
                         TextWrapping="Wrap" />
            </Grid>
          </Border>
        </Grid>
      </Border>

      <Border Grid.Column="2"
              Background="{DynamicResource CardBrush}"
              BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="1"
              CornerRadius="18"
              Padding="22">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <StackPanel Orientation="Horizontal">
            <Border Padding="10,5"
                    Background="{DynamicResource ThemeToggleBackgroundBrush}"
                    BorderBrush="{DynamicResource ThemeToggleBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="999">
              <TextBlock Text="{Binding ParticipantModeBadgeText}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         FontWeight="SemiBold" />
            </Border>
          </StackPanel>

          <Grid Grid.Row="1" Margin="0,20,0,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="170" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="Участники" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBlock Grid.Column="1" Text="{Binding ParticipantCountText}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />

            <TextBlock Grid.Row="1" Text="Формат" Margin="0,14,0,0" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,14,0,0" Text="{Binding FormatDisplay}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />

            <TextBlock Grid.Row="2" Text="Дата старта" Margin="0,14,0,0" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,14,0,0" Text="{Binding StartDateText}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />

            <TextBlock Grid.Row="3" Text="Игра" Margin="0,14,0,0" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,14,0,0" Text="{Binding GameName}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />

            <TextBlock Grid.Row="4" Text="Призовой фонд" Margin="0,14,0,0" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,14,0,0" Text="{Binding PrizePoolText}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />

            <TextBlock Grid.Row="5" Text="Организатор" Margin="0,14,0,0" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,14,0,0" Text="{Binding Organizer}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />

            <TextBlock Grid.Row="6" Text="Локация" Margin="0,14,0,0" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBlock Grid.Row="6" Grid.Column="1" Margin="0,14,0,0" Text="{Binding Location}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
          </Grid>
        </Grid>
      </Border>
    </Grid>

    <DockPanel Grid.Row="2" Margin="0,18,0,0" LastChildFill="False">
      <Button DockPanel.Dock="Right"
              Width="150"
              Content="Закрыть"
              Margin="0"
              Click="Close_Click" />
      <Button DockPanel.Dock="Right"
              Width="160"
              Content="Сетка турнира"
              Style="{StaticResource GhostButtonStyle}"
              Click="OpenBracket_Click" />
    </DockPanel>
  </Grid>
</Window>
