<Window x:Class="Tournaments.WPF.Views.EditEntityWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="520"
        Height="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanMinimize">
  <Grid Background="{DynamicResource SurfaceBrush}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Margin="24,24,24,10">
      <TextBlock x:Name="TitleText" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" />
      <TextBlock Margin="0,6,0,0"
                 Text="Заполните поля и сохраните изменения."
                 Foreground="{DynamicResource TextSecondaryBrush}" />
    </StackPanel>

    <ScrollViewer Grid.Row="1" Margin="24,0,24,10" VerticalScrollBarVisibility="Auto">
      <StackPanel x:Name="FieldsHost" />
    </ScrollViewer>

    <DockPanel Grid.Row="2" Margin="24,8,24,24">
      <Button DockPanel.Dock="Right" Width="120" Content="Сохранить" Click="Save_Click" />
      <Button Width="120" Content="Отмена" Style="{StaticResource GhostButtonStyle}" Click="Cancel_Click" />
    </DockPanel>
  </Grid>
</Window>
