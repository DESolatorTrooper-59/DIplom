<Window x:Class="Tournaments.WPF.Views.CrashDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ошибка приложения"
        Width="900"
        Height="640"
        MinWidth="760"
        MinHeight="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Closing="Window_Closing">
  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Margin="0,0,0,14">
      <TextBlock Text="Произошла необработанная ошибка"
                 FontSize="28"
                 FontWeight="Bold"
                 Foreground="{DynamicResource DangerTitleBrush}" />
      <TextBlock x:Name="SummaryText"
                 Margin="0,8,0,0"
                 FontSize="15"
                 Foreground="{DynamicResource TextSecondaryBrush}"
                 TextWrapping="Wrap" />
    </StackPanel>

    <Border Grid.Row="1"
            Margin="0,0,0,14"
            Padding="12"
            Background="{DynamicResource WarningBackgroundBrush}"
            BorderBrush="{DynamicResource WarningBorderBrush}"
            BorderThickness="1"
            CornerRadius="12">
      <TextBlock Text="Ниже показан стек-трейс. Текст можно выделить и скопировать для диагностики."
                 Foreground="{DynamicResource WarningForegroundBrush}"
                 TextWrapping="Wrap" />
    </Border>

    <Border Grid.Row="2"
            Background="{DynamicResource CardBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12">
      <TextBox x:Name="DetailsTextBox"
               Margin="0"
               Padding="14"
               Background="Transparent"
               BorderThickness="0"
               IsReadOnly="True"
               AcceptsReturn="True"
               AcceptsTab="True"
               TextWrapping="NoWrap"
               VerticalScrollBarVisibility="Auto"
               HorizontalScrollBarVisibility="Auto"
               FontFamily="Consolas"
               FontSize="13" />
    </Border>

    <StackPanel Grid.Row="3"
                Margin="0,14,0,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
      <Button Width="140"
              Content="Копировать"
              Style="{StaticResource GhostButtonStyle}"
              Click="Copy_Click" />
      <Button Width="140"
              Margin="0"
              Content="ОК"
              IsDefault="True"
              Click="Ok_Click" />
    </StackPanel>
  </Grid>
</Window>
