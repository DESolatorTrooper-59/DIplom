<Window x:Class="Tournaments.WPF.Views.TeamRenameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Изменение названия"
        Width="460"
        Height="260"
        MinWidth="420"
        MinHeight="240"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterOwner">
  <Grid Background="{DynamicResource SurfaceBrush}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Margin="24,24,24,10">
      <TextBlock Text="Название команды"
                 FontSize="24"
                 FontWeight="Bold"
                 Foreground="{DynamicResource TextPrimaryBrush}" />
      <TextBlock Margin="0,6,0,0"
                 Text="Введите новое название."
                 Foreground="{DynamicResource TextSecondaryBrush}" />
    </StackPanel>

    <StackPanel Grid.Row="1" Margin="24,0,24,10">
      <TextBlock Text="Название команды *"
                 FontWeight="SemiBold"
                 Margin="0,0,0,6" />
      <TextBox x:Name="TeamNameTextBox"
               Height="40"
               VerticalContentAlignment="Center" />
    </StackPanel>

    <DockPanel Grid.Row="2" Margin="24,8,24,24">
      <Button DockPanel.Dock="Right"
              Width="130"
              Height="40"
              Content="Сохранить"
              Click="Save_Click" />
      <Button Width="130"
              Height="40"
              Content="Отмена"
              Style="{StaticResource GhostButtonStyle}"
              Click="Cancel_Click" />
    </DockPanel>
  </Grid>
</Window>
