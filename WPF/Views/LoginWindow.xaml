<Window x:Class="Tournaments.WPF.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tournaments WPF"
        Width="600"
        Height="560"
        MinWidth="600"
        MinHeight="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
  <Grid Background="#FFF7FAFC">
    <StackPanel Margin="16"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Orientation="Horizontal">
      <Border x:Name="DbStatusBadge"
              Width="72"
              Height="56"
              Padding="10"
              Background="White"
              BorderBrush="#FFD9E2EC"
              BorderThickness="1"
              CornerRadius="16"
              ToolTip="Подключение к MS SQL Server не установлено.">
        <Canvas Width="44" Height="28">
          <Rectangle x:Name="SocketBody"
                     Width="14"
                     Height="16"
                     RadiusX="3"
                     RadiusY="3"
                     StrokeThickness="2"
                     Canvas.Left="3"
                     Canvas.Top="6" />
          <Ellipse x:Name="SocketHoleTop"
                   Width="2.6"
                   Height="2.6"
                   Canvas.Left="7"
                   Canvas.Top="11" />
          <Ellipse x:Name="SocketHoleBottom"
                   Width="2.6"
                   Height="2.6"
                   Canvas.Left="7"
                   Canvas.Top="15" />
          <Canvas x:Name="PlugGroup" Width="28" Height="18" Canvas.Left="16" Canvas.Top="5">
            <Canvas.RenderTransform>
              <TranslateTransform x:Name="PlugTransform" />
            </Canvas.RenderTransform>
            <Rectangle x:Name="PlugPinTop"
                       Width="5"
                       Height="2"
                       RadiusX="1"
                       RadiusY="1"
                       Canvas.Left="0"
                       Canvas.Top="4" />
            <Rectangle x:Name="PlugPinBottom"
                       Width="5"
                       Height="2"
                       RadiusX="1"
                       RadiusY="1"
                       Canvas.Left="0"
                       Canvas.Top="10" />
            <Rectangle x:Name="PlugBody"
                       Width="11"
                       Height="14"
                       RadiusX="2"
                       RadiusY="2"
                       StrokeThickness="2"
                       Canvas.Left="4"
                       Canvas.Top="2" />
            <Line x:Name="PlugCable"
                  X1="15"
                  Y1="9"
                  X2="27"
                  Y2="9"
                  StrokeThickness="2"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round" />
          </Canvas>
        </Canvas>
      </Border>

      <Button x:Name="TestModeButton"
              Width="72"
              Height="56"
              Margin="10,0,0,0"
              Padding="0"
              Background="Transparent"
              BorderThickness="0"
              Click="TestModeButton_Click"
              ToolTip="Переключиться на тестовый режим.">
        <Border x:Name="TestModeBadge"
                Padding="10"
                Background="White"
                BorderBrush="#FFD9E2EC"
                BorderThickness="1"
                CornerRadius="16">
          <Canvas Width="44" Height="28">
            <Line x:Name="RobotAntenna"
                  X1="22"
                  Y1="3"
                  X2="22"
                  Y2="7"
                  StrokeThickness="2"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round" />
            <Ellipse x:Name="RobotAntennaTip"
                     Width="4"
                     Height="4"
                     Canvas.Left="20"
                     Canvas.Top="0" />
            <Rectangle x:Name="RobotHead"
                       Width="20"
                       Height="14"
                       RadiusX="4"
                       RadiusY="4"
                       StrokeThickness="2"
                       Canvas.Left="12"
                       Canvas.Top="7" />
            <Ellipse x:Name="RobotEyeLeft"
                     Width="3"
                     Height="3"
                     Canvas.Left="17"
                     Canvas.Top="12" />
            <Ellipse x:Name="RobotEyeRight"
                     Width="3"
                     Height="3"
                     Canvas.Left="24"
                     Canvas.Top="12" />
            <Rectangle x:Name="RobotMouth"
                       Width="8"
                       Height="2.5"
                       RadiusX="1"
                       RadiusY="1"
                       Canvas.Left="18"
                       Canvas.Top="17" />
            <Line x:Name="RobotArmLeft"
                  X1="12"
                  Y1="14"
                  X2="7"
                  Y2="18"
                  StrokeThickness="2"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round" />
            <Line x:Name="RobotArmRight"
                  X1="32"
                  Y1="14"
                  X2="37"
                  Y2="18"
                  StrokeThickness="2"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round" />
          </Canvas>
        </Border>
      </Button>
    </StackPanel>

    <Border MaxWidth="440"
            Margin="24"
            Padding="28"
            Background="White"
            BorderBrush="#FFD9E2EC"
            BorderThickness="1"
            CornerRadius="16"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
          <TextBlock x:Name="TitleText"
                     Text="Tournaments WPF"
                     FontSize="26"
                     FontWeight="Bold"
                     Foreground="#FF102A43" />
          <TextBlock x:Name="SubtitleText"
                     Margin="0,8,0,0"
                     Text="Войдите под учётной записью организатора, чтобы открыть управление турнирами."
                     TextWrapping="Wrap"
                     Foreground="#FF486581" />
        </StackPanel>

        <Grid Grid.Row="1">
          <Grid x:Name="LoginModeGrid">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Логин" FontWeight="SemiBold" Margin="0,0,0,6" />
            <TextBox Grid.Row="1" x:Name="LoginTextBox" Height="38" KeyDown="LoginInput_KeyDown" />
            <TextBlock Grid.Row="2" Text="Пароль" FontWeight="SemiBold" Margin="0,8,0,6" />
            <PasswordBox Grid.Row="3" x:Name="PasswordTextBox" Height="38" KeyDown="LoginInput_KeyDown" />

            <Border Grid.Row="4"
                    x:Name="LoginMessageContainer"
                    Margin="0,12,0,16"
                    Padding="12"
                    Background="#FFFEE4E2"
                    BorderBrush="#FFFECACA"
                    BorderThickness="1"
                    CornerRadius="10"
                    Visibility="Collapsed">
              <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="100">
                <TextBlock x:Name="LoginMessageText"
                           Foreground="#FFB42318"
                           TextWrapping="Wrap" />
              </ScrollViewer>
            </Border>

            <Grid Grid.Row="5" HorizontalAlignment="Stretch">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <Button Grid.Column="0"
                      x:Name="LoginButton"
                      Width="110"
                      Margin="0"
                      HorizontalAlignment="Left"
                      Content="Войти"
                      Click="Login_Click" />
              <Button Grid.Column="2"
                      x:Name="SqlModeButton"
                      Width="140"
                      Margin="0"
                      HorizontalAlignment="Left"
                      Content="MS SQL Server"
                      Style="{StaticResource GhostButtonStyle}"
                      Click="SqlModeButton_Click" />
              <Button Grid.Column="4"
                      x:Name="CloseButton"
                      Width="110"
                      Margin="0"
                      HorizontalAlignment="Left"
                      Content="Закрыть"
                      Style="{StaticResource GhostButtonStyle}"
                      Click="Close_Click"
                      IsCancel="True" />
            </Grid>
          </Grid>

          <Grid x:Name="SqlModeGrid" Visibility="Collapsed">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Сервер" FontWeight="SemiBold" Margin="0,0,0,6" />
            <TextBox Grid.Row="1" x:Name="SqlServerTextBox" Height="38" KeyDown="SqlInput_KeyDown" />
            <TextBlock Grid.Row="2" Text="База данных" FontWeight="SemiBold" Margin="0,8,0,6" />
            <TextBox Grid.Row="3" x:Name="SqlDatabaseTextBox" Height="38" KeyDown="SqlInput_KeyDown" />

            <CheckBox Grid.Row="4"
                      x:Name="WindowsAuthCheckBox"
                      Content="Использовать Windows Authentication"
                      Margin="0,10,0,8"
                      Checked="WindowsAuthCheckBox_Changed"
                      Unchecked="WindowsAuthCheckBox_Changed" />

            <Grid Grid.Row="5">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <StackPanel Grid.Column="0">
                <TextBlock Text="Логин SQL Server" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBox x:Name="SqlUserTextBox" Height="38" KeyDown="SqlInput_KeyDown" />
              </StackPanel>

              <StackPanel Grid.Column="2">
                <TextBlock Text="Пароль SQL Server" FontWeight="SemiBold" Margin="0,0,0,6" />
                <PasswordBox x:Name="SqlPasswordTextBox" Height="38" KeyDown="SqlInput_KeyDown" />
              </StackPanel>
            </Grid>

            <Grid Grid.Row="6">
              <Border x:Name="SqlMessageContainer"
                      Margin="0,12,0,16"
                      Padding="12"
                      Background="#FFFEE4E2"
                      BorderBrush="#FFFECACA"
                      BorderThickness="1"
                      CornerRadius="10"
                      Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="90">
                  <TextBlock x:Name="SqlMessageText"
                             Foreground="#FFB42318"
                             TextWrapping="Wrap" />
                </ScrollViewer>
              </Border>

              <Border x:Name="SqlBusyOverlay"
                      Margin="0,12,0,16"
                      Background="#E6F8FAFC"
                      BorderBrush="#FFD9E2EC"
                      BorderThickness="1"
                      CornerRadius="12"
                      Visibility="Collapsed">
                <StackPanel Margin="16">
                  <TextBlock Text="Подключение к MS SQL Server..."
                             FontWeight="SemiBold"
                             Foreground="#FF102A43" />
                  <TextBlock Margin="0,6,0,10"
                             Text="Пожалуйста, подождите. Форма остаётся активной, пока идет проверка соединения."
                             TextWrapping="Wrap"
                             Foreground="#FF486581" />
                  <ProgressBar Height="10" IsIndeterminate="True" />
                </StackPanel>
              </Border>
            </Grid>

            <Grid Grid.Row="7" HorizontalAlignment="Stretch">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <Button Grid.Column="0"
                      x:Name="ConnectSqlButton"
                      Width="130"
                      Margin="0"
                      HorizontalAlignment="Left"
                      Content="Подключить"
                      Click="ConnectSql_Click" />
              <Button Grid.Column="2"
                      Width="110"
                      Margin="0"
                      HorizontalAlignment="Left"
                      Content="Назад"
                      Style="{StaticResource GhostButtonStyle}"
                      Click="BackToLogin_Click" />
              <Button Grid.Column="4"
                      Width="110"
                      Margin="0"
                      HorizontalAlignment="Left"
                      Content="Закрыть"
                      Style="{StaticResource GhostButtonStyle}"
                      Click="Close_Click" />
            </Grid>
          </Grid>
        </Grid>
      </Grid>
    </Border>
  </Grid>
</Window>

