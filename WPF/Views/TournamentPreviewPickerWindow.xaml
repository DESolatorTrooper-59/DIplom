<Window x:Class="Tournaments.WPF.Views.TournamentPreviewPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="760"
        Height="640"
        MinWidth="680"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
  <Grid Background="{DynamicResource SurfaceBrush}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Margin="24,24,24,12">
      <TextBlock Text="Превью турнира"
                 FontSize="24"
                 FontWeight="Bold"
                 Foreground="{DynamicResource TextPrimaryBrush}" />
      <TextBlock Margin="0,6,0,0"
                 Text="Готовое изображение или свой файл."
                 Foreground="{DynamicResource TextSecondaryBrush}" />
    </StackPanel>

    <Grid Grid.Row="1" Margin="24,0,24,12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="260" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <StackPanel>
        <Border Height="190"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                ClipToBounds="True">
          <Image x:Name="CurrentPreviewImage"
                 Stretch="UniformToFill" />
        </Border>
        <TextBlock x:Name="CurrentPreviewText"
                   Margin="0,12,0,0"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   TextWrapping="Wrap" />
      </StackPanel>

      <DockPanel Grid.Column="1" Margin="18,0,0,0">
        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    Margin="0,0,0,12">
          <Button Width="150"
                  Height="38"
                  Content="Загрузить свое"
                  Click="ChooseFile_Click" />
          <Button Width="130"
                  Height="38"
                  Content="По умолчанию"
                  Style="{StaticResource GhostButtonStyle}"
                  Click="DefaultPreview_Click" />
        </StackPanel>

        <ListBox x:Name="PreviewsListBox"
                 BorderThickness="0"
                 SelectionChanged="PreviewsListBox_SelectionChanged"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel IsItemsHost="True" />
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemContainerStyle>
            <Style TargetType="{x:Type ListBoxItem}">
              <Setter Property="Padding" Value="0" />
              <Setter Property="Margin" Value="0" />
              <Setter Property="HorizontalContentAlignment" Value="Stretch" />
              <Setter Property="Background" Value="Transparent" />
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="{x:Type ListBoxItem}">
                    <Border x:Name="Root"
                            Margin="0,0,12,12"
                            Padding="2"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="2"
                            CornerRadius="12">
                      <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                      <Trigger Property="IsSelected" Value="True">
                        <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                      </Trigger>
                      <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource GhostHoverBorderBrush}" />
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </ListBox.ItemContainerStyle>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border Width="150"
                      Background="{DynamicResource SubtleCardBrush}"
                      BorderBrush="{DynamicResource BorderBrush}"
                      BorderThickness="1"
                      CornerRadius="10"
                      ClipToBounds="True">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="92" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>

                  <Image Source="{Binding Image}"
                         Stretch="UniformToFill" />
                  <TextBlock Grid.Row="1"
                             Margin="10,8,10,10"
                             Text="{Binding Title}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             FontWeight="SemiBold"
                             TextTrimming="CharacterEllipsis" />
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Grid>

    <DockPanel Grid.Row="2" Margin="24,8,24,24">
      <Button DockPanel.Dock="Right"
              Width="120"
              Content="Сохранить"
              Click="Save_Click" />
      <Button Width="120"
              Content="Отмена"
              Style="{StaticResource GhostButtonStyle}"
              Click="Cancel_Click" />
    </DockPanel>
  </Grid>
</Window>
