<UserControl x:Class="Tournaments.WPF.Views.CrudPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Margin="0,0,0,16">
      <TextBlock x:Name="TitleText" FontSize="28" FontWeight="Bold" Foreground="#FF102A43" />
      <TextBlock Text="Добавление, редактирование, удаление, импорт CSV и быстрый поиск по выбранной сущности."
                 Foreground="#FF486581"
                 Margin="0,6,0,0" />
    </StackPanel>

    <Border Grid.Row="1" Padding="16" Background="White" BorderBrush="#FFD9E2EC" BorderThickness="1" CornerRadius="14">
      <Grid VerticalAlignment="Center">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Grid Margin="0,0,12,0" VerticalAlignment="Center">
          <TextBox x:Name="SearchTextBox"
                   Height="38"
                   Margin="0"
                   VerticalAlignment="Center"
                   VerticalContentAlignment="Center"
                   TextChanged="SearchTextBox_TextChanged" />
          <TextBlock Margin="12,0,0,0"
                     VerticalAlignment="Center"
                     Foreground="#7F486581"
                     IsHitTestVisible="False"
                     Text="Поиск">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </Grid>

        <Button Grid.Column="1" Width="120" Height="38" VerticalAlignment="Center" Content="Добавить" Click="Add_Click" />
        <Button Grid.Column="2" Width="120" Height="38" VerticalAlignment="Center" Content="Изменить" Click="Edit_Click" />
        <Button Grid.Column="3" Width="120" Height="38" VerticalAlignment="Center" Content="Удалить" Click="Delete_Click" />
      </Grid>
    </Border>

    <Border Grid.Row="2" Margin="0,16,0,0" Padding="12" Background="White" BorderBrush="#FFD9E2EC" BorderThickness="1" CornerRadius="14">
      <DataGrid x:Name="GridItems"
                AutoGeneratingColumn="GridItems_AutoGeneratingColumn"
                BeginningEdit="GridItems_BeginningEdit"
                RowEditEnding="GridItems_RowEditEnding"
                LostKeyboardFocus="GridItems_LostKeyboardFocus"
                MouseDoubleClick="GridItems_MouseDoubleClick" />
    </Border>

    <DockPanel Grid.Row="3" Margin="0,14,0,0" LastChildFill="False">
      <TextBox x:Name="StatusText"
               MinWidth="280"
               VerticalAlignment="Center"
               Foreground="#FF486581"
               Background="Transparent"
               BorderThickness="0"
               IsReadOnly="True"
               IsReadOnlyCaretVisible="True"
               ToolTip="Текст строки состояния можно выделить и скопировать." />
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
        <Button Width="140" Content="Импорт CSV" Style="{StaticResource GhostButtonStyle}" Click="Import_Click" />
        <Button Width="150" Content="Экспорт CSV" Style="{StaticResource GhostButtonStyle}" Click="Export_Click" />
        <Button Width="110" Margin="0,0,0,0" Content="Обновить" Style="{StaticResource GhostButtonStyle}" Click="Refresh_Click" />
      </StackPanel>
    </DockPanel>
  </Grid>
</UserControl>

