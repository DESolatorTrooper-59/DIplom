<UserControl x:Class="Tournaments.WPF.Views.TournamentCatalogPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Background="{DynamicResource SurfaceBrush}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Margin="0,0,0,16"
            Padding="22,20"
            Background="{DynamicResource PanelBrush}"
            BorderBrush="{DynamicResource AccentBrush}"
            BorderThickness="1"
            CornerRadius="18">
      <StackPanel>
        <TextBlock Text="Турниры"
                   FontSize="30"
                   FontWeight="Bold"
                   Foreground="{DynamicResource PanelTextBrush}" />
        <TextBlock x:Name="SubtitleText"
                   Margin="0,8,0,0"
                   Foreground="{DynamicResource PanelMutedTextBrush}"
                   TextWrapping="Wrap"
                   Text="Подборка активных турниров в формате карточной галереи с быстрым просмотром деталей." />
      </StackPanel>
    </Border>

    <Border Grid.Row="1"
            Padding="16"
            Background="{DynamicResource CardBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="16">
      <Grid VerticalAlignment="Center">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Grid Margin="0,0,14,0" VerticalAlignment="Center">
          <TextBox x:Name="SearchTextBox"
                   Height="40"
                   Margin="0"
                   VerticalAlignment="Center"
                   VerticalContentAlignment="Center"
                   TextChanged="SearchTextBox_TextChanged" />
          <TextBlock Margin="12,0,0,0"
                     VerticalAlignment="Center"
                     Foreground="{DynamicResource TextMutedBrush}"
                     IsHitTestVisible="False"
                     Text="Поиск по названию и игре">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </Grid>

        <Button Grid.Column="1"
                x:Name="CreateButton"
                Width="170"
                Height="40"
                VerticalAlignment="Center"
                Content="Создать турнир"
                Click="CreateButton_Click"
                Visibility="Collapsed" />
        <Button Grid.Column="2"
                x:Name="RefreshButton"
                Width="120"
                Height="40"
                Margin="0"
                VerticalAlignment="Center"
                Content="Обновить"
                Style="{StaticResource GhostButtonStyle}"
                Click="RefreshButton_Click" />
      </Grid>
    </Border>

    <Grid Grid.Row="2" Margin="0,16,0,0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <DockPanel LastChildFill="False">
        <TextBlock x:Name="SummaryText"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   FontSize="15" />
      </DockPanel>

      <Border Grid.Row="1"
              Margin="0,14,0,0"
              Padding="16"
              Background="{DynamicResource CardBrush}"
              BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="1"
              CornerRadius="16">
        <Grid>
          <ScrollViewer x:Name="CardsScrollViewer"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="CardsItemsControl">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel IsItemsHost="True" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Width="330"
                          Margin="0,0,18,18"
                          Background="{DynamicResource SubtleCardBrush}"
                          BorderBrush="{DynamicResource BorderBrush}"
                          BorderThickness="1"
                          CornerRadius="20"
                          SnapsToDevicePixels="True">
                    <Grid>
                      <Grid.RowDefinitions>
                        <RowDefinition Height="190" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                      </Grid.RowDefinitions>

                      <Border Grid.Row="0"
                              Background="{DynamicResource CardBrush}"
                              CornerRadius="20,20,0,0"
                              ClipToBounds="True">
                        <Grid>
                          <Image Source="{Binding PreviewImage}"
                                 Stretch="UniformToFill"
                                 Visibility="{Binding PreviewImageVisibility}" />

                          <Border Background="{DynamicResource CardBrush}"
                                  Visibility="{Binding PreviewPlaceholderVisibility}">
                            <Grid Margin="18">
                              <Border Width="98"
                                      Height="98"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Top"
                                      Background="{DynamicResource ThemeToggleActiveBackgroundBrush}"
                                      BorderBrush="{DynamicResource ThemeToggleActiveBorderBrush}"
                                      BorderThickness="1"
                                      CornerRadius="28" />
                              <TextBlock Margin="0,0,0,12"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Bottom"
                                         FontSize="26"
                                         FontWeight="Bold"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         Text="{Binding PreviewPlaceholderText}"
                                         TextWrapping="Wrap" />
                            </Grid>
                          </Border>

                          <Border Margin="14"
                                  Padding="10,5"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Top"
                                  Background="{DynamicResource ThemeToggleBackgroundBrush}"
                                  BorderBrush="{DynamicResource ThemeToggleBorderBrush}"
                                  BorderThickness="1"
                                  CornerRadius="999">
                            <TextBlock Text="{Binding GameName}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                          </Border>

                          <Border Margin="14"
                                  Padding="10,5"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Top"
                                  Background="{DynamicResource ThemeToggleActiveBackgroundBrush}"
                                  BorderBrush="{DynamicResource ThemeToggleActiveBorderBrush}"
                                  BorderThickness="1"
                                  CornerRadius="999">
                            <TextBlock Text="{Binding ParticipantModeBadgeText}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontWeight="SemiBold" />
                          </Border>
                        </Grid>
                      </Border>

                      <StackPanel Grid.Row="1" Margin="18,16,18,0">
                        <TextBlock Text="{Binding TournamentName}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding StartDateText}"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                      </StackPanel>

                      <Grid Grid.Row="2" Margin="18,18,18,0">
                        <Grid.RowDefinitions>
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="140" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Участники"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding ParticipantCountText}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontWeight="SemiBold" />

                        <TextBlock Grid.Row="1"
                                   Margin="0,10,0,0"
                                   Text="Формат"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBlock Grid.Row="1"
                                   Grid.Column="1"
                                   Margin="0,10,0,0"
                                   Text="{Binding FormatDisplay}"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                        <TextBlock Grid.Row="2"
                                   Margin="0,10,0,0"
                                   Text="Игра"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   Margin="0,10,0,0"
                                   Text="{Binding GameName}"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                        <TextBlock Grid.Row="3"
                                   Margin="0,10,0,0"
                                   Text="Призовой фонд"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBlock Grid.Row="3"
                                   Grid.Column="1"
                                   Margin="0,10,0,0"
                                   Text="{Binding PrizePoolText}"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                      </Grid>

                      <StackPanel Grid.Row="3"
                                  Margin="18,18,18,18">
                        <Button Height="40"
                                Content="Добавить участников"
                                IsEnabled="{Binding IsAdminAddPlayersEnabled}"
                                ToolTip="{Binding AdminAddPlayersToolTip}"
                                Visibility="{Binding AdminAddPlayersVisibility}"
                                Click="AddParticipants_Click" />
                        <Button Height="40"
                                Margin="0,0,0,12"
                                Content="{Binding RegisterButtonText}"
                                IsEnabled="{Binding IsRegisterEnabled}"
                                ToolTip="{Binding RegisterButtonToolTip}"
                                Visibility="{Binding RegisterButtonVisibility}"
                                Click="Register_Click" />
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                          </Grid.ColumnDefinitions>

                          <Button Grid.Column="0"
                                  Height="40"
                                  Content="Подробности"
                                  Style="{StaticResource GhostButtonStyle}"
                                  Click="Details_Click" />
                          <Button Grid.Column="2"
                                  Height="40"
                                  Content="Настройки"
                                  Style="{StaticResource GhostButtonStyle}"
                                  Visibility="{Binding SettingsButtonVisibility}"
                                  Click="Settings_Click" />
                        </Grid>
                      </StackPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

          <StackPanel x:Name="EmptyStatePanel"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Visibility="Collapsed">
            <TextBlock Text="По выбранному запросу турниры не найдены."
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       TextAlignment="Center" />
            <TextBlock Margin="0,10,0,0"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Text="Попробуйте очистить поиск или создать новый турнир."
                       TextAlignment="Center"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</UserControl>
