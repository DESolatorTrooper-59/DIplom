<Window x:Class="Tournaments.WPF.Views.UserProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Профиль"
        Width="520"
        Height="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanMinimize">
  <Grid Background="{DynamicResource SurfaceBrush}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Margin="24,24,24,12">
      <TextBlock Text="Профиль"
                 FontSize="28"
                 FontWeight="Bold"
                 Foreground="{DynamicResource TextPrimaryBrush}" />
      <TextBlock x:Name="SubtitleText"
                 Margin="0,8,0,0"
                 Foreground="{DynamicResource TextSecondaryBrush}"
                 Text="Измените данные учетной записи и при необходимости задайте новый пароль."
                 TextWrapping="Wrap" />
      <Border x:Name="InfoBanner"
              Margin="0,14,0,0"
              Padding="12,10"
              Background="{DynamicResource CardBrush}"
              BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="1"
              CornerRadius="12"
              Visibility="Collapsed">
        <TextBlock x:Name="InfoBannerText"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   TextWrapping="Wrap" />
      </Border>
    </StackPanel>

    <ScrollViewer Grid.Row="1"
                  Margin="24,0,24,12"
                  VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <TextBlock Text="Логин"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
        <TextBox x:Name="LoginTextBox"
                 Margin="0,6,0,14"
                 IsReadOnly="True"
                 IsReadOnlyCaretVisible="True" />

        <TextBlock Text="Никнейм"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
        <TextBox x:Name="NicknameTextBox"
                 Margin="0,6,0,14" />

        <TextBlock Text="Настоящее имя"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
        <TextBox x:Name="RealNameTextBox"
                 Margin="0,6,0,14" />

        <TextBlock Text="Страна"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
        <TextBox x:Name="CountryTextBox"
                 Margin="0,6,0,14" />

        <TextBlock Text="Дата рождения"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
        <DatePicker x:Name="BirthDatePicker"
                    Margin="0,6,0,22" />

        <Separator Margin="0,0,0,18" />

        <TextBlock Text="Новый пароль"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
        <PasswordBox x:Name="NewPasswordBox"
                     Margin="0,6,0,14" />

        <TextBlock Text="Подтвердите новый пароль"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
        <PasswordBox x:Name="ConfirmPasswordBox"
                     Margin="0,6,0,0" />
      </StackPanel>
    </ScrollViewer>

    <DockPanel Grid.Row="2" Margin="24,0,24,24">
      <Button DockPanel.Dock="Right"
              Width="140"
              Content="Сохранить"
              Click="Save_Click" />
      <Button Width="120"
              Content="Назад"
              Style="{StaticResource GhostButtonStyle}"
              Click="Cancel_Click" />
    </DockPanel>
  </Grid>
</Window>
