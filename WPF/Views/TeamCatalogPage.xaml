<UserControl x:Class="Tournaments.WPF.Views.TeamCatalogPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <UserControl.Resources>
    <Style x:Key="TeamCardButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
      <Setter Property="Margin" Value="0" />
      <Setter Property="Height" Value="42" />
      <Setter Property="Padding" Value="8,4" />
      <Setter Property="FontSize" Value="12" />
    </Style>
    <Style x:Key="TeamAddButtonStyle" TargetType="Button" BasedOn="{StaticResource TeamCardButtonStyle}">
      <Setter Property="Background" Value="#FF22A957" />
      <Setter Property="BorderBrush" Value="#FF22A957" />
      <Setter Property="Foreground" Value="#FFFFFFFF" />
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#FF1C8E49" />
          <Setter Property="BorderBrush" Value="#FF1C8E49" />
        </Trigger>
        <Trigger Property="IsEnabled" Value="False">
          <Setter Property="Opacity" Value="0.55" />
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="TeamDeleteButtonStyle" TargetType="Button" BasedOn="{StaticResource TeamCardButtonStyle}">
      <Setter Property="Background" Value="#FFE33E45" />
      <Setter Property="BorderBrush" Value="#FFE33E45" />
      <Setter Property="Foreground" Value="#FFFFFFFF" />
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#FFC83138" />
          <Setter Property="BorderBrush" Value="#FFC83138" />
        </Trigger>
        <Trigger Property="IsEnabled" Value="False">
          <Setter Property="Opacity" Value="0.55" />
        </Trigger>
      </Style.Triggers>
    </Style>
  </UserControl.Resources>

  <Grid Background="{DynamicResource SurfaceBrush}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Margin="0,0,0,16"
            Padding="22,20"
            Background="{DynamicResource SidebarPanelBrush}"
            BorderBrush="{DynamicResource AccentBrush}"
            BorderThickness="1"
            CornerRadius="18">
      <StackPanel>
        <TextBlock Text="Команды"
                   FontSize="30"
                   FontWeight="Bold"
                   Foreground="{DynamicResource PanelTextBrush}" />
        <TextBlock x:Name="SubtitleText"
                   Margin="0,8,0,0"
                   Foreground="{DynamicResource PanelMutedTextBrush}"
                   TextWrapping="Wrap" />
      </StackPanel>
    </Border>

    <Border Grid.Row="1"
            Padding="16"
            Background="{DynamicResource CardBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="16">
      <Grid VerticalAlignment="Center">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Grid Margin="0,0,14,0" VerticalAlignment="Center">
          <TextBox x:Name="SearchTextBox"
                   Height="40"
                   VerticalContentAlignment="Center"
                   TextChanged="SearchTextBox_TextChanged" />
          <TextBlock Margin="12,0,0,0"
                     VerticalAlignment="Center"
                     Foreground="{DynamicResource TextMutedBrush}"
                     IsHitTestVisible="False"
                     Text="Поиск по названию, стране или тренеру">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </Grid>

        <Button Grid.Column="1"
                x:Name="CreateButton"
                Width="170"
                Height="40"
                VerticalAlignment="Center"
                Content="Создать команду"
                Click="CreateButton_Click"
                Visibility="Collapsed" />
        <Button Grid.Column="2"
                x:Name="RefreshButton"
                Width="120"
                Height="40"
                Margin="0"
                VerticalAlignment="Center"
                Content="Обновить"
                Style="{StaticResource GhostButtonStyle}"
                Click="RefreshButton_Click" />
      </Grid>
    </Border>

    <Grid Grid.Row="2" Margin="0,16,0,0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <TextBlock x:Name="SummaryText"
                 VerticalAlignment="Center"
                 Foreground="{DynamicResource TextSecondaryBrush}"
                 FontSize="15" />

      <Border Grid.Row="1"
              Margin="0,14,0,0"
              Padding="16"
              Background="{DynamicResource CardBrush}"
              BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="1"
              CornerRadius="16">
        <Grid>
          <ScrollViewer x:Name="CardsScrollViewer"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="CardsItemsControl">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel IsItemsHost="True" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Width="320"
                          MinHeight="190"
                          Margin="0,0,18,18"
                          Padding="16"
                          Background="{DynamicResource SubtleCardBrush}"
                          BorderBrush="{DynamicResource BorderBrush}"
                          BorderThickness="1"
                          CornerRadius="12"
                          SnapsToDevicePixels="True">
                    <Grid>
                      <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                      </Grid.RowDefinitions>

                      <TextBlock Text="{Binding TeamName}"
                                 FontSize="22"
                                 FontWeight="Bold"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 TextAlignment="Center"
                                 TextWrapping="Wrap" />

                      <Grid Grid.Row="1" Margin="0,14,0,0">
                        <Grid.RowDefinitions>
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="105" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Страна"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Country}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis" />

                        <TextBlock Grid.Row="1"
                                   Margin="0,8,0,0"
                                   Text="Тренер"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBlock Grid.Row="1"
                                   Grid.Column="1"
                                   Margin="0,8,0,0"
                                   Text="{Binding CoachName}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis" />

                        <TextBlock Grid.Row="2"
                                   Margin="0,8,0,0"
                                   Text="Основана"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   Margin="0,8,0,0"
                                   Text="{Binding FoundedDateText}"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                        <TextBlock Grid.Row="3"
                                   Margin="0,8,0,0"
                                   Text="Участники"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBlock Grid.Row="3"
                                   Grid.Column="1"
                                   Margin="0,8,0,0"
                                   Text="{Binding ParticipantCountText}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontWeight="SemiBold" />
                      </Grid>

                      <UniformGrid Grid.Row="3"
                                   Margin="0,16,0,0"
                                   Columns="2"
                                   Rows="2">
                        <Button Style="{StaticResource TeamCardButtonStyle}"
                                Margin="0,0,8,8"
                                Click="ViewParticipants_Click">
                          <TextBlock Text="Просмотр участников"
                                     TextAlignment="Center"
                                     TextWrapping="Wrap" />
                        </Button>
                        <Button Style="{StaticResource TeamAddButtonStyle}"
                                Margin="0,0,0,8"
                                IsEnabled="{Binding CanManageData}"
                                ToolTip="{Binding ManageActionsToolTip}"
                                ToolTipService.ShowOnDisabled="True"
                                Click="AddParticipants_Click">
                          <TextBlock Text="Добавить участников"
                                     TextAlignment="Center"
                                     TextWrapping="Wrap"
                                     Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                        </Button>
                        <Button Style="{StaticResource TeamDeleteButtonStyle}"
                                Margin="0,0,8,0"
                                IsEnabled="{Binding CanManageData}"
                                ToolTip="{Binding ManageActionsToolTip}"
                                ToolTipService.ShowOnDisabled="True"
                                Click="DeleteTeam_Click">
                          <TextBlock Text="Удалить команду"
                                     TextAlignment="Center"
                                     TextWrapping="Wrap"
                                     Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                        </Button>
                        <Button Style="{StaticResource TeamCardButtonStyle}"
                                Margin="0"
                                IsEnabled="{Binding CanManageData}"
                                ToolTip="{Binding ManageActionsToolTip}"
                                ToolTipService.ShowOnDisabled="True"
                                Click="RenameTeam_Click">
                          <TextBlock Text="Изменить название"
                                     TextAlignment="Center"
                                     TextWrapping="Wrap" />
                        </Button>
                      </UniformGrid>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

          <StackPanel x:Name="EmptyStatePanel"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Visibility="Collapsed">
            <TextBlock Text="По выбранному запросу команды не найдены."
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       TextAlignment="Center" />
            <TextBlock Margin="0,10,0,0"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Text="Попробуйте очистить поиск или создать новую команду."
                       TextAlignment="Center"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</UserControl>
