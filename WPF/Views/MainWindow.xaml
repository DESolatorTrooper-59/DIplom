<Window x:Class="Tournaments.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tournaments WPF"
        Width="1440"
        Height="860"
        WindowStartupLocation="CenterScreen">
  <Grid Background="{DynamicResource SurfaceBrush}">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="280" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0" Background="{DynamicResource PanelBrush}">
      <DockPanel Margin="20">
        <Grid DockPanel.Dock="Top" Margin="0,0,0,24">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Row="1"
                      Grid.Column="0"
                      Grid.ColumnSpan="2"
                      Margin="0,8,0,0">
            <TextBlock Text="Tournament Control"
                       Foreground="{DynamicResource PanelTextBrush}"
                       FontSize="24"
                       FontWeight="Bold" />
            <TextBlock x:Name="UserText"
                       Margin="0,10,0,0"
                       Foreground="{DynamicResource PanelMutedTextBrush}"
                       TextWrapping="Wrap" />
          </StackPanel>

          <Button Grid.Row="0"
                  Grid.Column="1"
                  x:Name="ThemeToggleButton"
                  Width="46"
                  Height="46"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Top"
                  Style="{StaticResource FlatIconButtonStyle}"
                  Click="ThemeToggleButton_Click"
                  ToolTip="Переключить тему.">
            <Border x:Name="ThemeToggleBadge"
                    Width="46"
                    Height="46"
                    Background="{DynamicResource ThemeToggleBackgroundBrush}"
                    BorderBrush="{DynamicResource ThemeToggleBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
              <TextBlock x:Name="ThemeToggleIcon"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         FontFamily="Segoe UI Symbol"
                         FontSize="22"
                         Foreground="{DynamicResource ThemeToggleIconBrush}"
                         Text="☀" />
            </Border>
          </Button>
        </Grid>

        <Button DockPanel.Dock="Bottom"
                Margin="0,16,0,0"
                Content="Выйти"
                Style="{StaticResource GhostButtonStyle}"
                Click="Logout_Click" />

        <ListBox x:Name="EntitiesList"
                 Background="Transparent"
                 BorderThickness="0"
                 Foreground="{DynamicResource PanelTextBrush}"
                 SelectionChanged="EntitiesList_SelectionChanged">
          <ListBox.ItemContainerStyle>
            <Style TargetType="ListBoxItem">
              <Setter Property="Margin" Value="0,0,0,8" />
              <Setter Property="Padding" Value="14,10" />
              <Setter Property="Background" Value="#00000000" />
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="10">
                      <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                      <Trigger Property="IsSelected" Value="True">
                        <Setter TargetName="Root" Property="Background" Value="{DynamicResource PanelItemSelectedBrush}" />
                      </Trigger>
                      <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="Root" Property="Background" Value="{DynamicResource PanelItemHoverBrush}" />
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </ListBox.ItemContainerStyle>
        </ListBox>
      </DockPanel>
    </Border>

    <Grid Grid.Column="1" Margin="20" Background="{DynamicResource SurfaceBrush}">
      <ContentControl x:Name="PageHost" />
    </Grid>
  </Grid>
</Window>
