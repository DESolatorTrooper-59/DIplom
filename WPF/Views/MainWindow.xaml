<Window x:Class="Tournaments.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tournaments WPF"
        Width="1440"
        Height="860"
        WindowStartupLocation="CenterScreen">
  <Grid Background="{DynamicResource SurfaceBrush}">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="280" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0" Background="{DynamicResource SidebarPanelBrush}">
      <DockPanel Margin="20">
        <Grid DockPanel.Dock="Top" Margin="0,0,0,24">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Row="0"
                      Grid.Column="1"
                      Orientation="Horizontal"
                      VerticalAlignment="Top"
                      Margin="0,0,12,0">
            <Button x:Name="ProfileButton"
                    Width="46"
                    Height="46"
                    VerticalAlignment="Top"
                    Style="{StaticResource FlatIconButtonStyle}"
                    Click="ProfileButton_Click"
                    ToolTip="Открыть профиль.">
              <Border Style="{DynamicResource SidebarBadgeBorderStyle}">
                <TextBlock Style="{DynamicResource SidebarProfileIconStyle}"
                           Text="&#xE77B;" />
              </Border>
            </Button>
            <TextBlock x:Name="ProfileNameText"
                       Style="{DynamicResource SidebarProfileNameTextStyle}" />
          </StackPanel>

          <StackPanel Grid.Row="1"
                      Grid.Column="0"
                      Grid.ColumnSpan="3"
                      Margin="0,8,0,0">
            <TextBlock Text="Tournament Control"
                       Style="{DynamicResource SidebarTitleTextStyle}" />
            <TextBlock x:Name="UserText"
                       Style="{DynamicResource SidebarUserInfoTextStyle}" />
          </StackPanel>

          <Button Grid.Row="0"
                  Grid.Column="2"
                  x:Name="ThemeToggleButton"
                  Width="46"
                  Height="46"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Top"
                  Style="{StaticResource FlatIconButtonStyle}"
                  Click="ThemeToggleButton_Click"
                  ToolTip="Переключить тему.">
            <Border x:Name="ThemeToggleBadge"
                    Style="{DynamicResource SidebarBadgeBorderStyle}">
              <TextBlock x:Name="ThemeToggleIcon"
                         Style="{DynamicResource SidebarThemeIconStyle}"
                         Text="☀" />
            </Border>
          </Button>
        </Grid>

        <Button DockPanel.Dock="Bottom"
                Margin="0,16,0,0"
                Content="Выйти"
                Style="{StaticResource GhostButtonStyle}"
                Click="Logout_Click" />

        <ListBox x:Name="EntitiesList"
                 Background="Transparent"
                 BorderThickness="0"
                 Foreground="{DynamicResource SidebarTextBrush}"
                 ItemContainerStyle="{DynamicResource SidebarNavigationItemStyle}"
                 SelectionChanged="EntitiesList_SelectionChanged">
        </ListBox>
      </DockPanel>
    </Border>

    <Grid Grid.Column="1" Margin="20" Background="{DynamicResource SurfaceBrush}">
      <ContentControl x:Name="PageHost" />
    </Grid>
  </Grid>
</Window>
