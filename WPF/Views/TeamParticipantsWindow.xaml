<Window x:Class="Tournaments.WPF.Views.TeamParticipantsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Участники команды"
        Width="720"
        Height="620"
        MinWidth="640"
        MinHeight="480"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="20" Background="{DynamicResource SurfaceBrush}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel>
      <TextBlock x:Name="TitleText"
                 FontSize="28"
                 FontWeight="Bold"
                 Foreground="{DynamicResource TextPrimaryBrush}" />
      <TextBlock x:Name="SubtitleText"
                 Margin="0,8,0,0"
                 Foreground="{DynamicResource TextSecondaryBrush}"
                 TextWrapping="Wrap" />
    </StackPanel>

    <Border Grid.Row="1"
            Margin="0,18,0,0"
            Padding="14"
            Background="{DynamicResource CardBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12">
      <Grid>
        <TextBox x:Name="SearchTextBox"
                 Height="40"
                 VerticalContentAlignment="Center"
                 TextChanged="SearchTextBox_TextChanged" />
        <TextBlock Margin="12,0,0,0"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource TextMutedBrush}"
                   IsHitTestVisible="False"
                   Text="Поиск по нику, имени, роли или стране">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="Visibility" Value="Collapsed" />
              <Style.Triggers>
                <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                  <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>
      </Grid>
    </Border>

    <TextBlock Grid.Row="2"
               x:Name="SummaryText"
               Margin="0,16,0,0"
               Foreground="{DynamicResource TextSecondaryBrush}"
               FontSize="15" />

    <Border Grid.Row="3"
            Margin="0,14,0,0"
            Padding="16"
            Background="{DynamicResource CardBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12">
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
          <Border Padding="16"
                  Background="{DynamicResource SubtleCardBrush}"
                  BorderBrush="{DynamicResource BorderBrush}"
                  BorderThickness="1"
                  CornerRadius="10">
            <StackPanel>
              <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           Text="Состав команды"
                           VerticalAlignment="Center"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
                <Border DockPanel.Dock="Right"
                        Padding="10,5"
                        Background="{DynamicResource ThemeToggleBackgroundBrush}"
                        BorderBrush="{DynamicResource ThemeToggleBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="999">
                  <TextBlock x:Name="CurrentCountText"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             FontWeight="SemiBold" />
                </Border>
              </DockPanel>

              <ItemsControl x:Name="CurrentPlayersItemsControl"
                            Margin="0,14,0,0">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Margin="0,0,0,12"
                            Padding="16"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                          <TextBlock Text="{Binding DisplayName}"
                                     FontSize="18"
                                     FontWeight="Bold"
                                     Foreground="{DynamicResource TextPrimaryBrush}" />
                          <TextBlock Margin="0,6,0,0"
                                     Text="{Binding Details}"
                                     Foreground="{DynamicResource TextSecondaryBrush}"
                                     TextWrapping="Wrap" />
                        </StackPanel>

                        <Border Grid.Column="1"
                                Margin="16,0,0,0"
                                Padding="10,5"
                                VerticalAlignment="Center"
                                Background="{DynamicResource ThemeToggleBackgroundBrush}"
                                BorderBrush="{DynamicResource ThemeToggleBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="999">
                          <TextBlock Text="{Binding RoleText}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     FontWeight="SemiBold" />
                        </Border>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <TextBlock x:Name="CurrentEmptyText"
                         Visibility="Collapsed"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>

          <Border x:Name="AvailableSectionPanel"
                  Margin="0,16,0,0"
                  Padding="16"
                  Background="{DynamicResource SubtleCardBrush}"
                  BorderBrush="{DynamicResource BorderBrush}"
                  BorderThickness="1"
                  CornerRadius="10">
            <StackPanel>
              <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           Text="Можно добавить"
                           VerticalAlignment="Center"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
                <Border DockPanel.Dock="Right"
                        Padding="10,5"
                        Background="{DynamicResource ThemeToggleActiveBackgroundBrush}"
                        BorderBrush="{DynamicResource ThemeToggleActiveBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="999">
                  <TextBlock x:Name="AvailableCountText"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             FontWeight="SemiBold" />
                </Border>
              </DockPanel>

              <ItemsControl x:Name="AvailablePlayersItemsControl"
                            Margin="0,14,0,0">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button Margin="0,0,0,12"
                            Padding="16"
                            HorizontalContentAlignment="Stretch"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            Click="AddParticipant_Click">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                          <TextBlock Text="{Binding DisplayName}"
                                     FontSize="20"
                                     FontWeight="Bold"
                                     Foreground="{DynamicResource TextPrimaryBrush}" />
                          <TextBlock Margin="0,6,0,0"
                                     Text="{Binding Details}"
                                     Foreground="{DynamicResource TextSecondaryBrush}"
                                     TextWrapping="Wrap" />
                        </StackPanel>

                        <Border Grid.Column="1"
                                Margin="16,0,0,0"
                                Padding="10,5"
                                VerticalAlignment="Center"
                                Background="{DynamicResource ThemeToggleActiveBackgroundBrush}"
                                BorderBrush="{DynamicResource ThemeToggleActiveBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="999">
                          <TextBlock Text="Добавить"
                                     FontWeight="SemiBold"
                                     Foreground="{DynamicResource TextPrimaryBrush}" />
                        </Border>
                      </Grid>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <TextBlock x:Name="AvailableEmptyText"
                         Visibility="Collapsed"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <DockPanel Grid.Row="4"
               Margin="0,18,0,0"
               LastChildFill="False">
      <Button DockPanel.Dock="Right"
              Width="140"
              Height="40"
              Content="Закрыть"
              Click="Close_Click" />
    </DockPanel>
  </Grid>
</Window>
