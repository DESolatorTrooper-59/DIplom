<Window x:Class="Tournaments.WPF.Views.BracketPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="1360"
        Height="860"
        MinWidth="980"
        MinHeight="620"
        Background="#FFF5F8FC"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <StackPanel>
      <TextBlock x:Name="TitleText" FontSize="30" FontWeight="Bold" Foreground="#FF102A43" />
      <TextBlock x:Name="SubtitleText"
                 Margin="0,8,0,0"
                 Foreground="#FF486581"
                 TextWrapping="Wrap" />
    </StackPanel>

    <Border Grid.Row="1"
            Margin="0,18,0,0"
            Padding="16"
            Background="White"
            BorderBrush="#FFD9E2EC"
            BorderThickness="1"
            CornerRadius="14">
      <TextBlock x:Name="SummaryText"
                 Foreground="#FF486581"
                 TextWrapping="Wrap" />
    </Border>

    <Border Grid.Row="2"
            Margin="0,18,0,0"
            Padding="16"
            Background="White"
            BorderBrush="#FFD9E2EC"
            BorderThickness="1"
            CornerRadius="14">
      <Grid>
        <TextBlock x:Name="EmptyStateText"
                   Foreground="#FF486581"
                   FontSize="16"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   Visibility="Collapsed" />

        <ScrollViewer x:Name="BracketScrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
          <Canvas x:Name="BracketCanvas" Background="#FFF4F4FB" />
        </ScrollViewer>
      </Grid>
    </Border>
  </Grid>
</Window>
