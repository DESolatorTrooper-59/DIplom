<Window x:Class="Tournaments.WPF.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tournaments WPF"
        Width="560"
        Height="500"
        MinWidth="560"
        MinHeight="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
  <Grid Background="#FFF7FAFC">
    <Border MaxWidth="420"
            Margin="24"
            Padding="28"
            Background="White"
            BorderBrush="#FFD9E2EC"
            BorderThickness="1"
            CornerRadius="16"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
          <TextBlock Text="Tournaments WPF"
                     FontSize="26"
                     FontWeight="Bold"
                     Foreground="#FF102A43" />
          <TextBlock Margin="0,8,0,0"
                     Text="Войдите под учётной записью организатора, чтобы открыть управление турнирами."
                     TextWrapping="Wrap"
                     Foreground="#FF486581" />
        </StackPanel>

        <TextBlock Grid.Row="1" Text="Логин" FontWeight="SemiBold" Margin="0,0,0,6" />
        <TextBox Grid.Row="2" x:Name="LoginTextBox" Height="38" KeyDown="Input_KeyDown" />

        <TextBlock Grid.Row="3" Text="Пароль" FontWeight="SemiBold" Margin="0,10,0,6" />
        <PasswordBox Grid.Row="4" x:Name="PasswordTextBox" Height="38" KeyDown="Input_KeyDown" />

        <Border Grid.Row="5"
                x:Name="MessageContainer"
                Margin="0,12,0,16"
                Padding="12"
                Background="#FFFEE4E2"
                BorderBrush="#FFFECACA"
                BorderThickness="1"
                CornerRadius="10"
                Visibility="Collapsed">
          <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="100">
            <TextBlock x:Name="MessageText"
                       Foreground="#FFB42318"
                       TextWrapping="Wrap" />
          </ScrollViewer>
        </Border>

        <Grid Grid.Row="6" HorizontalAlignment="Stretch">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <Button Grid.Column="0"
                  x:Name="LoginButton"
                  Width="110"
                  Margin="0"
                  HorizontalAlignment="Left"
                  Content="Войти"
                  Click="Login_Click"
                  IsDefault="True" />
          <Button Grid.Column="2"
                  x:Name="SqlConnectButton"
                  Width="140"
                  Margin="0"
                  HorizontalAlignment="Left"
                  Content="MS SQL Server"
                  Style="{StaticResource GhostButtonStyle}"
                  Click="SqlConnect_Click" />
          <Button Grid.Column="4"
                  x:Name="CloseButton"
                  Width="110"
                  Margin="0"
                  HorizontalAlignment="Left"
                  Content="Закрыть"
                  Style="{StaticResource GhostButtonStyle}"
                  Click="Close_Click"
                  IsCancel="True" />
        </Grid>
      </Grid>
    </Border>
  </Grid>
</Window>
